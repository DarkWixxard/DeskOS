# DeskOS – zentrale Port-Konfiguration
#
# Diese Datei nach ".env" kopieren und die Werte anpassen, um Port-Konflikte
# mit anderen Anwendungen zu vermeiden.
#
# Wirkt sich aus auf:
#   - lokale Entwicklung   (npm run dev)
#   - Docker               (docker compose liest .env automatisch)
#   - Produktion           (setup.sh übernimmt die Werte für systemd/Build)
#
# Hinweis: NEXT_PUBLIC_BACKEND_PORT wird von Next.js beim BUILD ins Frontend
# eingebacken. npm run dev und setup.sh setzen das automatisch aus BACKEND_PORT.

# Web-Dashboard (Next.js)
FRONTEND_PORT=4000

# API + WebSocket (Express/Socket.IO)
BACKEND_PORT=4001

# Oszi-Service (Python/Flask)
OSZI_PORT=4002

# MQTT-Broker (IANA-Standard 1883; nur bei Bedarf ändern)
MQTT_PORT=1883

# --- Sicherheit (empfohlen) ---
# Gemeinsamer Token für API + WebSocket. Gesetzt = Schutz aktiv. Wird an Backend
# UND Frontend (NEXT_PUBLIC_DESKOS_TOKEN) durchgereicht. Erzeugen: openssl rand -hex 24
# DESKOS_TOKEN=
# Erlaubte CORS-Origins (Komma-getrennt). Leer = LAN-freundlich (Origin spiegeln).
# CORS_ORIGINS=
