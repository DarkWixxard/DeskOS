# DeskOS – zentrale Port-Konfiguration
#
# Diese Datei nach ".env" kopieren und die Werte anpassen, um Port-Konflikte
# mit anderen Anwendungen zu vermeiden.
#
# Wirkt sich aus auf:
#   - lokale Entwicklung   (npm run dev)
#   - Docker               (docker compose liest .env automatisch)
#   - Produktion           (setup.sh übernimmt die Werte für systemd/Build)
#
# Hinweis: NEXT_PUBLIC_BACKEND_PORT wird von Next.js beim BUILD ins Frontend
# eingebacken. npm run dev und setup.sh setzen das automatisch aus BACKEND_PORT.

# Web-Dashboard (Next.js)
FRONTEND_PORT=4000

# API + WebSocket (Express/Socket.IO)
BACKEND_PORT=4001

# Oszi-Service (Python/Flask)
OSZI_PORT=4002

# MQTT-Broker (IANA-Standard 1883; nur bei Bedarf ändern)
MQTT_PORT=1883

# --- Sicherheit (empfohlen) ---
# Gemeinsamer Token für API + WebSocket. Gesetzt = Schutz aktiv. Wird an Backend
# UND Frontend (NEXT_PUBLIC_DESKOS_TOKEN) durchgereicht. Erzeugen: openssl rand -hex 24
# DESKOS_TOKEN=
# Erlaubte CORS-Origins (Komma-getrennt). Leer = LAN-freundlich (Origin spiegeln).
# CORS_ORIGINS=
# Rate-Limit: max. Requests je Minute und IP auf /api (Standard 300).
# RATE_LIMIT_MAX=300

# --- deej (Hardware-Lautstärkeregler, optional) ---
# Physischer Lautstärke-Mixer nach https://github.com/omriharel/deej. Alles lässt
# sich auch im Dashboard unter "Audio" einstellen; diese Variablen sind für den
# headless/Kiosk-Betrieb. Voraussetzung für echte Hardware: `npm i serialport`
# im Backend (optionale Abhängigkeit).
# DEEJ_PORT=/dev/ttyUSB0        # serieller Port (Windows z. B. COM3)
# DEEJ_BAUD=9600                # Baudrate (deej-Firmware-Standard)
# DEEJ_SLIDERS=4                # Anzahl der Regler
# DEEJ_INVERT=false            # Regler invertieren (0 % oben)
# DEEJ_NOISE=default           # Rauschunterdrückung: low | default | high
# DEEJ_AUTOCONNECT=false       # beim Start automatisch verbinden (Port muss gesetzt sein)

# --- Bambu Lab A1 (3D-Drucker, optional) ---
# Vorkonfiguration für headless/Kiosk-Betrieb. Alternativ im Dashboard unter
# Plugins → "Bambu Lab A1" eintragen (dort sicher in der DB gespeichert).
# Voraussetzung am Drucker: LAN-Modus/Zugangscode aktiv.
# BAMBU_IP=192.168.178.50
# BAMBU_ACCESS_CODE=
# BAMBU_SERIAL=
