# Port für API + WebSocket. Zentral steuerbar über die Root-.env (BACKEND_PORT).
# PORT wird weiterhin als Fallback unterstützt.
BACKEND_PORT=4001
NODE_ENV=development
DATABASE_PATH=./descos.db
LOG_LEVEL=debug

# --- Sicherheit ---
# Gemeinsamer Token für API + WebSocket. Ist er gesetzt, müssen alle Clients ihn
# mitschicken (Frontend bekommt ihn via NEXT_PUBLIC_DESKOS_TOKEN). Leer = Auth aus.
# Token erzeugen z. B. mit:  openssl rand -hex 24
# DESKOS_TOKEN=
# Erlaubte CORS-Origins (Komma-getrennt). Leer = Anfrage-Origin spiegeln (LAN-ok);
# '*' = alles erlauben.  Beispiel: http://localhost:4000,http://192.168.178.50:4000
# CORS_ORIGINS=
# Max. API-Requests pro Minute (Rate-Limit).
# RATE_LIMIT_MAX=300

# MQTT (ESP32 / Sensor-Nodes). Standardmäßig startet DeskOS einen eingebetteten
# Broker (aedes) – nur an 127.0.0.1 gebunden (sicher). Simulator + Backend laufen
# lokal. Für echte LAN-Nodes MQTT_HOST=0.0.0.0 setzen UND Credentials vergeben.
MQTT_PORT=1883
# MQTT_HOST=127.0.0.1
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_BROKER=mqtt://localhost:1883   # externer Broker (dann kein eigener)
# MQTT_EMBEDDED=false

# WLED-Lichter, die beim ersten Start angelegt werden (JSON-Array). Werden danach
# in der Datenbank verwaltet (Hinzufügen/Bearbeiten/Entfernen im RGB-Dashboard).
# Standard, wenn nicht gesetzt: Zimmerlicht + Schreibtisch-Regal.
# WLED_LIGHTS=[{"name":"Zimmerlicht","ip":"192.168.178.126"},{"name":"Schreibtisch-Regal","ip":"192.168.178.49"}]
# WLED_POLL_INTERVAL_MS=7000

# --- Spotify-Plugin (Now Playing + Wiedergabesteuerung) ---
# Client ID/Secret kommen normalerweise über das Plugin-UI (Dashboard → Plugins →
# Spotify → Zahnrad). Alternativ hier setzen (haben Vorrang nur, wenn im UI leer).
# Anlegen unter https://developer.spotify.com/dashboard
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# Redirect-URI: MUSS exakt so in den Spotify-App-Einstellungen eingetragen sein.
# Standard ist der lokale Loopback (Spotify verlangt 127.0.0.1, nicht localhost).
# Bei Zugriff über LAN/Tailscale anpassen, z. B. http://<host>:4001/api/spotify/callback
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:4001/api/spotify/callback

# --- Discord-Plugin (eigenes Konto verbinden, KEIN Bot) ---
# Client ID/Secret kommen normalerweise über das Plugin-UI (Dashboard → Plugins →
# Discord → Zahnrad). Alternativ hier setzen (haben Vorrang nur, wenn im UI leer).
# Anlegen unter https://discord.com/developers/applications ("New Application" –
# es muss KEIN Bot hinzugefügt werden, nur der OAuth2-Tab wird benötigt).
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# Redirect-URI: MUSS exakt so unter OAuth2 -> Redirects in der Discord-App
# eingetragen sein. Bei Zugriff über LAN/Tailscale anpassen.
# DISCORD_REDIRECT_URI=http://localhost:4001/api/discord/callback
